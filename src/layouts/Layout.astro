---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Pablo Anttila — Frontend engineer and interface designer based in Stockholm." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@3/css/pico.min.css">
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
